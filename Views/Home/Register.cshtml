@model ERP.Models.User
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="~/assets/vendor/css/rtl/core.css" />
    <link rel="stylesheet" href="~/assets/vendor/css/rtl/theme-default.css" />
</head>
<body>
    <div class="container mt-5" style="max-width:400px;">
        <h2>Create Account</h2>

        <form asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <label>Email</label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger d-block"></span>

            <label>Password</label>
            <input asp-for="Password" class="form-control" type="password" />
            <span asp-validation-for="Password" class="text-danger d-block"></span>

            <button type="submit" class="btn btn-primary mt-2">Create Account</button>

            <p class="mt-3">
                Already have an account?
                <a asp-action="Login">Login</a>
            </p>
        </form>
    </div>
</body>
</html>
