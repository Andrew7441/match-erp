<!DOCTYPE html>
<html lang="en" class="light-style layout-navbar-fixed layout-menu-fixed" dir="ltr"
      data-theme="theme-default"
      data-assets-path="~/assets/"
      data-template="vertical-menu-template">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />
    <title>@ViewData["Title"] - ERP</title>
    <link rel="icon" type="image/x-icon" href="~/assets/img/favicon/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/assets/vendor/fonts/boxicons.css" />
    <link rel="stylesheet" href="~/assets/vendor/fonts/fontawesome.css" />
    <link rel="stylesheet" href="~/assets/vendor/css/rtl/core.css" />
    <link rel="stylesheet" href="~/assets/vendor/css/rtl/theme-default.css" />
    <link rel="stylesheet" href="~/assets/css/demo.css" />
    <link rel="stylesheet" href="~/assets/vendor/libs/perfect-scrollbar/perfect-scrollbar.css" />
    <script src="~/assets/vendor/js/helpers.js"></script>
    <script src="~/assets/js/config.js"></script>
</head>
<body>
    <div class="layout-wrapper layout-content-navbar">
        <div class="layout-container">

            @await Html.PartialAsync("_Sidebar")
            @* Loads Views/Shared/_Sidebar.cshtml — sidebar is isolated here *@

            <div class="layout-page">

                @await Html.PartialAsync("_Navbar")
                @* Loads Views/Shared/_Navbar.cshtml — navbar is isolated here *@

                <div class="content-wrapper">
                    @RenderBody()
                    @* This is where Staff.cshtml / Index.cshtml / Create.cshtml get injected *@

                    <footer class="content-footer footer bg-footer-theme">
                        <div class="container-xxl py-2">
                            &copy; @DateTime.Now.Year <strong>ERP System</strong>
                        </div>
                    </footer>
                    <div class="content-backdrop fade"></div>
                </div>

            </div>
        </div>
        <div class="layout-overlay layout-menu-toggle"></div>
    </div>

    @await Html.PartialAsync("_FooterScripts")
    @* Loads Views/Shared/_FooterScripts.cshtml — all JS isolated here *@

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>